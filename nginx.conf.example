# Add this location block inside your existing sandipdhillon.co.uk server block.
# The site already handles HTTPS — this extends it with the project path.

# Redirect the no-trailing-slash form so it doesn't fall through to the portfolio SPA
location = /projects/workflowarchitect {
    return 301 /projects/workflowarchitect/;
}

# Static frontend
location /projects/workflowarchitect/ {
    alias /var/www/workflow-architect/apps/web/dist/;
    try_files $uri $uri/ /projects/workflowarchitect/index.html;

    # Cache static assets aggressively
    location ~* \.(js|css|woff2?|png|svg|ico)$ {
        expires 1y;
        add_header Cache-Control "public, immutable";
    }
}

# API proxy
location /projects/workflowarchitect/api/ {
    proxy_pass http://127.0.0.1:3002/api/;
    proxy_http_version 1.1;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection 'upgrade';
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_cache_bypass $http_upgrade;

    # SSE / streaming support
    proxy_buffering off;
    proxy_read_timeout 120s;
    proxy_connect_timeout 10s;
    chunked_transfer_encoding on;

    # Security headers
    add_header X-Content-Type-Options nosniff;
    add_header X-Frame-Options DENY;
    add_header X-XSS-Protection "1; mode=block";
}
